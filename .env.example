# ── Discord Bot ───────────────────────────────────────────────────────────────
# Required. Obtain from https://discord.com/developers/applications

# Discord bot token (keep secret)
BOT_TOKEN=your_discord_bot_token_here

# Discord user ID of the bot account
BOT_USER_ID=your_bot_user_id_here

# ID of the Discord server the bot operates in
DISCORD_SERVER_ID=your_discord_server_id_here

# ── Discord OAuth2 (for web login) ────────────────────────────────────────────
# Required for web UI Discord login. Obtain from:
# https://discord.com/developers/applications → your app → OAuth2

# Application (client) ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# Client secret (keep secret)
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# OAuth2 redirect URI — must match exactly what is registered in the Developer Portal
DISCORD_REDIRECT_URI=https://your-hostname.example.com/login

# ── Web Frontend ───────────────────────────────────────────────────────────────
# Optional. Controls the URL used for "Open in browser" Discord buttons.
# Must end with a trailing slash.
# Default: https://lausyncti4.thefords.cloud/game/
#
# WEB_BASE_URL=https://your-hostname.example.com/game/
